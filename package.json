{
  "name": "lightforge-docs",
  "private": true,
  "version": "0.0.6",
  "license": "MIT",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:docs": "npm run dev --workspace=apps/docs",
    "dev:blog": "npm run dev --workspace=apps/blog",
    "build:docs": "npm run build --workspace=apps/docs",
    "build:blog": "npm run build --workspace=apps/blog",
    "build": "npm run build:docs && npm run build:blog",
    "lint:links": "npm run lint:links --workspaces --if-present"
  },
  "engines": {
    "node": ">=20"
  },
  "overrides": {
    "@astrojs/sitemap": "3.6.1"
  },
  "description": "Documentation and blog platform for lightforge.dev"
}
